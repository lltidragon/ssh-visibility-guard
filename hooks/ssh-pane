#!/usr/bin/env bash
# ssh-pane — run SSH in a VISIBLE tmux pane, registering @ssh_host so tools
# (ssh-guard, status line) read the host deterministically instead of guessing.
#
#   ssh-pane open <host> [ssh-args...]   open a visible ssh pane in Claude's window
#   ssh-pane run  <host> <command...>    reuse/open the host's pane, run cmd, print output
#   ssh-pane list                        list registered ssh panes
#
# Why this exists: tmux has no "before command" hook and can't see the AI's
# tool-call intent, so blocking bare ssh stays in the PreToolUse guard. This
# wrapper only makes the EXECUTION layer stable: one place that opens the pane,
# stamps the host onto the pane (#{@ssh_host}), and polls a marker for output.
set -euo pipefail

die() { echo "ssh-pane: $*" >&2; exit 2; }
command -v tmux >/dev/null || die "tmux not found"

# Window where the caller (Claude / a subagent that inherited $TMUX_PANE) lives.
# That is the window the user is actually watching — open panes HERE.
self_window() {
  local p="${TMUX_PANE:-}"
  if [ -n "$p" ]; then
    tmux display-message -t "$p" -p '#{session_name}:#{window_index}'
  else
    tmux display-message -p '#{session_name}:#{window_index}' 2>/dev/null || echo ""
  fi
}

# An existing visible ssh pane for $host in the self window (matched by @ssh_host).
find_pane() {
  local host="$1" win; win="$(self_window)"
  [ -n "$win" ] || return 0
  tmux list-panes -t "$win" -F '#{pane_id} #{pane_current_command} #{@ssh_host}' 2>/dev/null \
    | awk -v h="$host" '$2=="ssh" && $3==h {print $1; exit}'
}

# Busy-poll until the pane is ready for input (best-effort; never hard-fail).
wait_prompt() {
  local i screen
  for i in $(seq 1 200); do
    # Capture the WHOLE screen, not tail -N: a fresh ssh pane renders its prompt
    # (including "Password:") at the TOP, so tail would miss it. Also match
    # password / passphrase prompts, whose "*: " ending isn't a shell prompt.
    screen="$(tmux capture-pane -t "$1" -p 2>/dev/null || true)"
    printf '%s' "$screen" | grep -qE '[#$%>] *$|[Pp]assword:|[Pp]assphrase|\(yes/no' && return 0
  done
  return 0
}

open_pane() {
  local host="$1"; shift || true
  local win; win="$(self_window)"
  [ -n "$win" ] || die "no tmux window (run inside tmux)"
  local pane
  # accept-new: don't stall on the first-connect host-key (yes/no) prompt.
  # ConnectTimeout: fail fast instead of hanging when the host is unreachable.
  pane="$(tmux split-window -h -t "$win" -P -F '#{pane_id}' "ssh -o StrictHostKeyChecking=accept-new -o ConnectTimeout=20 $host $*")"
  # If ssh died instantly (bad host alias / missing key / unreachable), the pane is
  # already gone and set-option fails with "can't find pane" — translate that into a
  # clear connection error instead of a cryptic tmux message.
  tmux set-option -p -t "$pane" @ssh_host "$host" 2>/dev/null \
    || die "ssh exited immediately for '$host' — connection failed (check host alias in ~/.ssh/config, key, or network; if ~/.ssh was reset, restore it first)."
  [ -n "${TMUX_PANE:-}" ] && tmux select-pane -t "$TMUX_PANE" 2>/dev/null || true
  wait_prompt "$pane"
  echo "$pane"
}

cmd_open() {
  [ $# -ge 1 ] || die "open needs <host>"
  local host="$1"; shift || true
  local pane; pane="$(find_pane "$host")"
  [ -n "$pane" ] && { echo "$pane"; return; }
  open_pane "$host" "$@"
}

cmd_run() {
  [ $# -ge 2 ] || die "run needs <host> <command...>"
  local host="$1"; shift
  local cmd="$*"
  local pane; pane="$(find_pane "$host")"
  [ -n "$pane" ] || pane="$(open_pane "$host")"

  # Unique start/end markers so we can slice THIS run's output out of the
  # pane's scrollback (avoids matching a previous run's residue).
  local s="S_${$}_${RANDOM}" e="E_${$}_${RANDOM}"
  # Pick a marker syntax the remote shell understands. Windows cmd.exe doesn't treat
  # ';' as a separator and has no $? — a unix-style marker line is echoed verbatim and
  # never completes. Detect a cmd prompt (DRIVE:\...>) and use '&' + %errorlevel%;
  # unix and PowerShell both handle the ';' form.
  local lastln; lastln="$(tmux capture-pane -t "$pane" -p 2>/dev/null | grep -v '^[[:space:]]*$' | tail -1)"
  if printf '%s' "$lastln" | grep -qE '[A-Za-z]:\\.*>[[:space:]]*$' && ! printf '%s' "$lastln" | grep -q 'PS '; then
    tmux send-keys -t "$pane" "echo $s& $cmd& echo ${e}_%errorlevel%" Enter   # Windows cmd.exe
  else
    tmux send-keys -t "$pane" "echo $s; $cmd; echo ${e}_\$?" Enter             # unix / PowerShell
  fi

  local i raw=""
  for i in $(seq 1 300); do
    raw="$(tmux capture-pane -t "$pane" -p -S -500 2>/dev/null || true)"
    # Match the REAL end marker (E_..._<numeric exitcode>), NOT the command-echo line
    # which contains the literal "E_..._%errorlevel%" (cmd) or "E_..._$?" (unix). The
    # echo shows up instantly on send-keys; matching it would break before the command
    # has actually run — fatal on slow remotes like Windows cmd over ssh.
    printf '%s\n' "$raw" | grep -qE "${e}_[0-9]" && break
    # Stop early if the remote is clearly waiting for interactive input — no point
    # polling while it sits at a password / passphrase / host-key prompt. Only look at
    # the LAST few lines: a live prompt is at the bottom of the screen. Scanning the
    # whole -S -500 scrollback would match a STALE host-key "(yes/no" from an earlier
    # connect and break on the very first poll, before the command has produced output.
    printf '%s\n' "$raw" | tail -n 3 | grep -qE '[Pp]assword:|[Pp]assphrase|\(yes/no' && break
    # A bare busy-loop blows through all iterations in milliseconds — long before a
    # round-trip to a remote (especially Windows cmd over ssh) produces the end
    # marker. Pace the poll so it actually waits for output (300 × 0.2s = 60s cap).
    sleep 0.2
  done

  # Print everything between the start marker and the end marker.
  printf '%s\n' "$raw" | awk -v s="$s" -v e="$e" '
    $0 ~ s {f=1; next}
    $0 ~ e {f=0}
    f {print}'

  # '|| true': when the remote stalls (e.g. a password prompt) there is no
  # end-marker, so grep returns non-zero; under set -e + pipefail that would kill
  # the script and make `ssh-pane run` exit 1 — misleading the caller into thinking
  # it failed, even though the visible pane was already created (the real goal).
  local code
  code="$(printf '%s\n' "$raw" | grep -oE "${e}_[0-9]+" | tail -1 | sed 's/.*_//')" || true
  if [ -n "$code" ]; then
    echo "[ssh-pane: $host pane $pane, remote exit=$code]" >&2
  else
    echo "[ssh-pane: $host pane $pane is open & visible; no completion marker yet — still running, or waiting for input like a password]" >&2
  fi
}

cmd_list() {
  local rows
  rows="$(tmux list-panes -a -F '#{pane_id}  #{session_name}:#{window_index}  cmd=#{pane_current_command}  host=#{@ssh_host}' 2>/dev/null | grep 'cmd=ssh' || true)"
  [ -n "$rows" ] && echo "$rows" || echo "(no ssh panes)"
}

case "${1:-}" in
  open) shift; cmd_open "$@";;
  run)  shift; cmd_run "$@";;
  list) cmd_list;;
  *) echo "usage: ssh-pane {open <host> [ssh-args]|run <host> <command...>|list}" >&2; exit 2;;
esac
